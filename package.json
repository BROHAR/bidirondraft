{
  "name": "auction-draft-simulator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Fantasy Football Auction Draft Simulator",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "start": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "refresh-projections": "node scripts/refresh-projections/index.mjs",
    "audit-bidding": "vitest run --config scripts/audit.vitest.config.mjs && cat scripts/bidding-audit.out.txt",
    "audit-taco": "vitest run --config scripts/audit-taco.vitest.config.mjs && cat scripts/taco-audit.out.txt"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.0.0",
    "express": "^5.2.1",
    "immer": "^10.0.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
